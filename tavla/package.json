{
    "name": "tavla",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "firebaseFunctions"
    ],
    "browserslist": [
        "defaults"
    ],
    "scripts": {
        "dev": "next dev & firebase emulators:start --only auth,firestore,storage --project=ent-tavla-dev",
        "dev:persist": "next dev & yarn emulators",
        "emulators": "firebase emulators:start --only auth,firestore,storage --project=ent-tavla-dev --import=./.db --export-on-exit",
        "build": "next build",
        "build:prod": "NEXT_PUBLIC_ENV=prod next build",
        "typecheck": "tsc --noEmit --incremental false",
        "start": "next start",
        "generate": "graphql-codegen",
        "lint": "biome check .",
        "format": "biome format .",
        "fix": "biome check --write .",
        "build-start": "next build && next start",
        "postinstall": "cd .. && husky install ./.husky",
        "prepare": "husky"
    },
    "lint-staged": {
        "**/*.{ts,tsx,js,jsx,json,css,md,yaml,yml}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    },
    "dependencies": {
        "@entur/alert": "0.18.8",
        "@entur/button": "4.0.4",
        "@entur/chip": "0.10.8",
        "@entur/dropdown": "8.1.0",
        "@entur/expand": "3.7.5",
        "@entur/form": "9.3.0",
        "@entur/icons": "8.4.4",
        "@entur/layout": "3.5.0",
        "@entur/loader": "0.6.5",
        "@entur/menu": "6.1.3",
        "@entur/modal": "1.8.8",
        "@entur/table": "4.10.8",
        "@entur/tokens": "3.22.3",
        "@entur/tooltip": "5.3.8",
        "@entur/typography": "2.1.5",
        "@sentry/nextjs": "10.44.0",
        "@types/jsdom": "28.0.0",
        "dompurify": "3.3.3",
        "firebase": "12.10.0",
        "firebase-admin": "13.7.0",
        "firebase-functions": "7.2.2",
        "graphql": "16.13.1",
        "jsdom": "29.0.0",
        "lodash": "4.17.23",
        "nanoid": "5.1.7",
        "next": "16.1.7",
        "posthog-js": "1.360.2",
        "posthog-node": "5.28.2",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "swr": "2.4.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@graphql-codegen/cli": "6.2.1",
        "@graphql-codegen/import-types-preset": "4.0.0",
        "@graphql-codegen/typed-document-node": "6.1.7",
        "@graphql-codegen/typescript": "5.0.9",
        "@graphql-codegen/typescript-operations": "5.0.9",
        "@types/lodash": "4.17.24",
        "@types/node": "25.5.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/semver": "7.7.1",
        "autoprefixer": "10.4.27",
        "firebase-tools": "15.10.1",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "postcss": "8.5.8",
        "tailwindcss": "3.4.19",
        "typescript": "5.9.3"
    },
    "packageManager": "yarn@4.10.3",
    "engines": {
        "node": "22.13.0"
    },
    "resolutions": {
        "basic-ftp": "5.2.0",
        "minimatch": "9.0.7",
        "tar": "7.5.11",
        "immutable": "3.8.3"
    }
}
