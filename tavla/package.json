{
    "name": "tavla",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "firebaseFunctions"
    ],
    "browserslist": [
        "defaults"
    ],
    "scripts": {
        "dev": "next dev & firebase emulators:start --only auth,firestore,storage --project=ent-tavla-dev",
        "dev:persist": "next dev & yarn emulators",
        "emulators": "firebase emulators:start --only auth,firestore,storage --project=ent-tavla-dev --import=./.db --export-on-exit=./.db",
        "build": "next build",
        "build:prod": "NEXT_PUBLIC_ENV=prod next build",
        "typecheck": "tsc --noEmit --incremental false",
        "start": "next start",
        "generate": "graphql-codegen",
        "lint": "biome check .",
        "format": "biome format .",
        "fix": "biome check --write .",
        "build-start": "next build && next start",
        "postinstall": "cd .. && husky install ./.husky",
        "prepare": "husky"
    },
    "lint-staged": {
        "**/*.{ts,tsx,js,jsx,json,css,md,yaml,yml}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    },
    "dependencies": {
        "@entur/alert": "0.19.3",
        "@entur/button": "4.0.10",
        "@entur/chip": "0.10.15",
        "@entur/dropdown": "8.1.7",
        "@entur/expand": "3.7.11",
        "@entur/form": "9.3.7",
        "@entur/icons": "8.4.6",
        "@entur/layout": "3.7.4",
        "@entur/loader": "0.7.3",
        "@entur/menu": "6.3.0",
        "@entur/modal": "1.8.15",
        "@entur/table": "4.10.15",
        "@entur/tokens": "3.24.0",
        "@entur/tooltip": "5.3.15",
        "@entur/typography": "2.1.11",
        "@google-cloud/logging": "11.2.3",
        "@sentry/nextjs": "10.62.0",
        "@types/jsdom": "28.0.3",
        "dompurify": "3.4.11",
        "firebase": "12.15.0",
        "firebase-admin": "13.10.0",
        "firebase-functions": "7.2.5",
        "graphql": "16.14.2",
        "jsdom": "29.1.1",
        "lodash": "4.18.1",
        "nanoid": "5.1.16",
        "next": "16.2.9",
        "posthog-js": "1.395.0",
        "posthog-node": "5.38.6",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "swr": "2.4.2",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@graphql-codegen/cli": "7.1.3",
        "@graphql-codegen/import-types-preset": "4.0.1",
        "@graphql-codegen/typed-document-node": "7.0.3",
        "@graphql-codegen/typescript": "6.0.2",
        "@graphql-codegen/typescript-operations": "6.0.5",
        "@types/lodash": "4.17.24",
        "@types/node": "25.9.2",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/semver": "7.7.1",
        "autoprefixer": "10.5.2",
        "firebase-tools": "15.22.3",
        "husky": "9.1.7",
        "lint-staged": "17.0.8",
        "postcss": "8.5.16",
        "tailwindcss": "3.4.19",
        "typescript": "6.0.3"
    },
    "packageManager": "yarn@4.10.3",
    "engines": {
        "node": "22.13.0"
    },
    "resolutions": {
        "basic-ftp": "5.3.1",
        "minimatch": "9.0.7",
        "tar": "7.5.11",
        "immutable": "3.8.3",
        "protobufjs": "7.6.3"
    }
}
